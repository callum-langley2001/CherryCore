{
    "name": "callum/cherrycore",
    "description": "A simple PHP framework for building web applications",
    "keywords": ["Framework", "PHP", "CherryCore"],
    "type": "library",
    "license": "GPLv3",
    "readme": "",
    "time": "",
    "support": {
        "issues": "https://github.com/callum-langley2001/CherryCore/issues",
        "source": "https://github.com/callum-langley2001/CherryCore",
        "wiki": "https://github.com/callum-langley2001/CherryCore/wiki"
    },
    "authors": [
        {
            "name": "Callum Langley",
            "email": "callumlangley9@gmail.com",
            "role": "Developer"
        }
    ],
    "minimum-stability": "alpha",
    "require": {
        "php": ">=8.2.24",
        "ext-mbstring": "*",
        "ext-iconv": "*",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-simplexml": "*"
    },
    "autoload": {
        "psr-4": {
            "Cherry\\": "src/Cherry"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cherry\\Tests\\": "tests/"
        }
